{
  "manifest_version": 3,
  "name": "Chesskit Analyzer",
  "version": "1.2",
  "description": "One-click: finish a Chess.com game and jump straight to Chesskit analysis automatically.",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://www.chess.com/*", "*://chess.com/*"],
      "js": ["content_chess.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://chesskit.org/*"],
      "js": ["content_chesskit.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
